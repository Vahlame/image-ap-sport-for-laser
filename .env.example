# Copiar a ".env" en la raiz del repo (el archivo .env esta en .gitignore).
# Cargar variables en la shell antes de correr scripts, o usar un gestor que las inyecte.

# API del wizard (evita conflicto con otros programas en :8000, p. ej. Manager.exe)
LASER_API_PORT=18765

# LPIPS / score v4 (PyTorch)
LASER_LPIPS_DEVICE=auto

# Techo VRAM por proceso (GiB); "off" desactiva. En GPUs <= ~7.5 GiB el codigo usa 5.5 por defecto si no defines nada.
LASER_CUDA_MEMORY_CAP_GIB=5.5

# Hugging Face: descargas de SAM2 y otros modelos (mejor rate limit y menos avisos).
# Crear token (lectura suele bastar): https://huggingface.co/settings/tokens
# PowerShell:  $env:HF_TOKEN = "hf_xxxxxxxx"
# Bash:        export HF_TOKEN=hf_xxxxxxxx
# Alternativa nombre legacy soportado por el repo y por huggingface_hub:
# HUGGING_FACE_HUB_TOKEN=hf_xxxxxxxx
